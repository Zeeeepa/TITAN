# ─── Stage 1: Build ──────────────────────────────────────────
FROM node:22-slim AS builder
WORKDIR /app
COPY package*.json ./
COPY scripts ./scripts
COPY tsconfig.json ./
RUN npm ci
COPY src ./src
RUN npm run build

# ─── Stage 2: Production (GPU-enabled) ───────────────────────
FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

WORKDIR /app

# Install Node.js, Python3, and GPU dependencies
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    bash \
    git \
    wget \
    gnupg \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get install -y --no-install-recommends \
       python3 \
       python3-pip \
       python3-dev \
       ffmpeg \
       sox \
       libsndfile1 \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf python3 /usr/bin/python

# Install Node.js dependencies
COPY package*.json ./
COPY scripts ./scripts
RUN npm ci --omit=dev && npm cache clean --force

# Copy built application
COPY --from=builder /app/dist ./dist
COPY assets ./assets
COPY ui/dist ./ui/dist
COPY .env.example ./.env.example

# Copy voice components
COPY titan-voice-server ./titan-voice-server
COPY titan-voice-agent ./titan-voice-agent
COPY scripts/qwen3-tts-server.py ./scripts/qwen3-tts-server.py

# Create non-root titan user
RUN groupadd -g 1001 titan && useradd -u 1001 -g titan -m -d /home/titan titan \
    && mkdir -p /home/titan/.titan \
    && chown -R titan:titan /home/titan

USER titan

ENV NODE_ENV=production
ENV TITAN_HOME=/home/titan/.titan
ENV TITAN_GATEWAY_HOST=0.0.0.0
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=utility,compute

EXPOSE 48420

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://127.0.0.1:48420/api/health || exit 1

ENTRYPOINT ["node", "dist/cli/index.js"]
CMD ["gateway"]
