{
  "name": "titan-agent",
  "version": "1.0.0",
  "description": "TITAN — The Intelligent Task Automation Network. An autonomous AI agent framework.",
  "author": "Tony Elliott (https://github.com/Djtony707)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Djtony707/TITAN.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "titan": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gateway": "tsx src/cli/index.ts gateway",
    "gateway:watch": "tsx watch src/cli/index.ts gateway",
    "doctor": "tsx src/cli/index.ts doctor",
    "onboard": "tsx src/cli/index.ts onboard"
  },
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "llm",
    "assistant",
    "automation",
    "chatbot",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "discord",
    "telegram",
    "slack",
    "whatsapp"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "ora": "^8.1.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.12.0",
    "@typescript-eslint/parser": "^8.12.0",
    "eslint": "^8.57.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "tsup": {
    "entry": [
      "src/cli/index.ts"
    ],
    "format": [
      "esm"
    ],
    "target": "node20",
    "splitting": false,
    "sourcemap": true,
    "clean": true,
    "dts": false,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  }
}