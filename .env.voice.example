# TITAN Voice Stack — Environment Configuration
#
# Copy this file to .env and adjust for your setup:
#   cp .env.voice.example .env
#
# ── Distributed Setup ───────────────────────────────────
# Run TITAN gateway + voice stack on a lightweight device (Pi 5, Mini PC)
# Run Ollama on a GPU machine for inference
#
# Pi 5 (gateway node):    npm start -- gateway
# GPU PC (inference node): ollama serve

# IP/hostname of the machine running Ollama (GPU PC)
OLLAMA_HOST=192.168.1.11

# Ollama model for voice responses (smaller = faster voice latency)
OLLAMA_MODEL=qwen3:0.6b

# TITAN gateway address (usually localhost if voice stack runs on same machine)
TITAN_HOST=localhost
TITAN_PORT=48420

# Kokoro TTS voice (af_heart, af_sky, am_adam, etc.)
TTS_VOICE=af_heart

# Auth token for TITAN gateway (leave empty if auth mode is 'none')
TITAN_AUTH_TOKEN=
